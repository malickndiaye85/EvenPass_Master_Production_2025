rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Admin Finance UID (Super Admin)
    function isAdminFinance() {
      return request.auth != null && request.auth.uid == 'Tnq8Isi0fATmidMwEuVrw1SAJkI3';
    }

    // Authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Event owner
    function isEventOwner(eventId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/events/$(eventId)).data.organizer_id == request.auth.uid;
    }

    // OPS Manager Events (accès aux événements)
    function isOpsManagerEvents() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ops_events';
    }

    // OPS Manager Transport (accès aux véhicules)
    function isOpsManagerTransport() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ops_transport';
    }

    // Staff member (controleur, ops, etc)
    function isStaff() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ops_events', 'ops_transport', 'controleur'];
    }

    // ============================================
    // FINANCES COLLECTION - ADMIN ONLY
    // ============================================
    match /finances/{document=**} {
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // LOGS SYSTÈME - ADMIN ONLY
    // ============================================
    match /logs/{document=**} {
      allow read, write: if isAdminFinance();
    }

    match /systemLogs/{document=**} {
      allow read, write: if isAdminFinance();
    }

    match /auditLogs/{document=**} {
      allow read, write: if isAdminFinance();
    }

    match /securityLogs/{document=**} {
      allow read: if isStaff() || isAdminFinance();
      allow write: if isAdminFinance();
    }

    // ============================================
    // EVENTS COLLECTION
    // ============================================
    match /events/{eventId} {
      // Public : Lecture seule des événements disponibles
      allow read: if true;

      // Organisateurs : Création de nouveaux événements
      allow create: if isAuthenticated() &&
                      request.resource.data.organizer_id == request.auth.uid;

      // Organisateurs et OPS Events : Modification
      allow update: if isEventOwner(eventId) || isOpsManagerEvents() || isAdminFinance();

      // Organisateurs : Suppression de leurs propres événements
      allow delete: if isEventOwner(eventId) || isAdminFinance();

      // ============================================
      // TICKETS SOUS-COLLECTION
      // ============================================
      match /tickets/{ticketId} {
        // Public : Lecture des tickets disponibles
        allow read: if true;

        // Organisateur et OPS Events : Gestion des tickets
        allow write: if isEventOwner(eventId) || isOpsManagerEvents() || isAdminFinance();
      }

      // ============================================
      // SCANS SOUS-COLLECTION
      // ============================================
      match /scans/{scanId} {
        // OPS Events, Organisateur et Admin : Lecture et écriture
        allow read, write: if isEventOwner(eventId) || isOpsManagerEvents() || isAdminFinance();
      }

      // ============================================
      // ATTENDEES SOUS-COLLECTION
      // ============================================
      match /attendees/{attendeeId} {
        // OPS Events, Organisateur et Admin : Lecture
        allow read: if isEventOwner(eventId) || isOpsManagerEvents() || isAdminFinance();

        // Création lors de l'achat de ticket
        allow create: if isAuthenticated();

        // Modification interdite sauf admin
        allow update, delete: if isAdminFinance();
      }
    }

    // ============================================
    // OPS_EVENTS COLLECTION (Scanner Events)
    // ============================================
    match /ops_events/{opsId} {
      // OPS Events et Admin : Lecture
      allow read: if isOpsManagerEvents() || isAdminFinance();

      // Création par OPS Events
      allow create: if isOpsManagerEvents() || isAdminFinance();

      // Modification et suppression par admin uniquement
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // OPS_EVENTS_SCANS COLLECTION
    // ============================================
    match /ops_events_scans/{scanId} {
      // OPS Events et Admin : Lecture et écriture
      allow read, write: if isOpsManagerEvents() || isAdminFinance();
    }

    // ============================================
    // ORDERS COLLECTION (Commandes)
    // ============================================
    match /orders/{orderId} {
      // Utilisateur : Lecture de ses propres commandes
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Création lors de l'achat
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // USERS COLLECTION (Profils)
    // ============================================
    match /users/{userId} {
      // Permettre la création de profil utilisateur lors de l'inscription
      // CRITIQUE: Permet création avec n'importe quel UID (pour drivers avec UID custom)
      allow create: if isAuthenticated() || true;

      // Utilisateur : Lecture et modification de son propre profil
      allow read, update: if isAuthenticated() && request.auth.uid == userId;

      // Suppression uniquement par l'utilisateur ou admin
      allow delete: if (isAuthenticated() && request.auth.uid == userId) || isAdminFinance();

      // Admin et OPS : Accès total
      allow read, write: if isAdminFinance() || isStaff();
    }

    // ============================================
    // ORGANIZERS COLLECTION
    // ============================================
    match /organizers/{organizerId} {
      // Lecture publique des profils organisateurs
      allow read: if true;

      // Création de profil organisateur lors de l'inscription
      // CRITIQUE: Permet création même si UID ne correspond pas (inscription en cours)
      allow create: if isAuthenticated() || true;

      // Organisateur : Modification de son propre profil
      allow update: if isAuthenticated() && request.auth.uid == organizerId;

      // Suppression uniquement par admin
      allow delete: if isAdminFinance();

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // DRIVERS COLLECTION (Chauffeurs)
    // ============================================
    match /drivers/{driverId} {
      // Lecture publique des profils chauffeurs
      allow read: if true;

      // Création de profil chauffeur lors de l'inscription
      // CRITIQUE: Permet création sans authentification (inscription avec UID custom driver_phone)
      allow create: if true;

      // Chauffeur : Modification de son propre profil
      allow update: if isAuthenticated() && request.auth.uid == driverId;

      // Suppression uniquement par admin
      allow delete: if isAdminFinance();

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      // Utilisateur : Lecture de ses propres paiements
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Création lors du paiement
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Admin Finance : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // STATISTICS COLLECTION
    // ============================================
    match /statistics/{document=**} {
      // Lecture pour les organisateurs de leurs propres stats
      allow read: if isAuthenticated();

      // Écriture interdite sauf admin
      allow write: if isAdminFinance();
    }

    // ============================================
    // CONFIGURATION SYSTÈME
    // ============================================
    match /config/{document=**} {
      // Lecture publique de la configuration
      allow read: if true;

      // Modification admin uniquement
      allow write: if isAdminFinance();
    }

    // ============================================
    // BACKGROUNDS COLLECTION (Landing Pages)
    // ============================================
    match /backgrounds/{document=**} {
      // Lecture publique pour affichage landing pages
      allow read: if true;

      // Modification admin uniquement
      allow write: if isAdminFinance();
    }

    // ============================================
    // SETTINGS COLLECTION
    // ============================================
    match /settings/{document=**} {
      // Lecture publique des paramètres
      allow read: if true;

      // Modification admin uniquement
      allow write: if isAdminFinance();
    }

    // ============================================
    // HOME ADS COLLECTION
    // ============================================
    match /home_ads/{document=**} {
      // Lecture publique pour affichage page d'accueil
      allow read: if true;

      // Modification admin uniquement
      allow write: if isAdminFinance();
    }

    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    match /categories/{categoryId} {
      // Lecture publique des catégories
      allow read: if true;

      // Création/Modification par organisateurs authentifiés
      allow create, update: if isAuthenticated();

      // Suppression admin uniquement
      allow delete: if isAdminFinance();
    }

    match /event_categories/{categoryId} {
      // Lecture publique des catégories d'événements
      allow read: if true;

      // Création/Modification par organisateurs authentifiés
      allow create, update: if isAuthenticated();

      // Suppression admin uniquement
      allow delete: if isAdminFinance();
    }

    // ============================================
    // SECURITY AGENTS COLLECTION (Contrôleurs)
    // ============================================
    match /security_agents/{agentId} {
      // Lecture pour tous les authentifiés
      allow read: if isAuthenticated();

      // Création par organisateurs et admin
      allow create: if isAuthenticated();

      // Modification et suppression par admin uniquement
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // TICKET TYPES COLLECTION
    // ============================================
    match /ticket_types/{ticketTypeId} {
      // Lecture publique des types de billets
      allow read: if true;

      // Création par organisateurs authentifiés
      allow create: if isAuthenticated();

      // Modification et suppression par organisateurs et admin
      allow update, delete: if isAuthenticated() || isAdminFinance();
    }

    // ============================================
    // MODIFICATION REQUESTS COLLECTION
    // ============================================
    match /modification_requests/{requestId} {
      // Organisateurs : Création de demandes
      allow create: if isAuthenticated() &&
                      request.resource.data.organizer_id == request.auth.uid;

      // Organisateurs : Lecture de leurs propres demandes
      allow read: if isAuthenticated() &&
                    resource.data.organizer_id == request.auth.uid;

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // PAYOUT REQUESTS COLLECTION
    // ============================================
    match /payout_requests/{requestId} {
      // Organisateurs : Création de demandes de payout
      allow create: if isAuthenticated() &&
                      request.resource.data.organizer_id == request.auth.uid;

      // Organisateurs : Lecture de leurs propres demandes
      allow read: if isAuthenticated() &&
                    resource.data.organizer_id == request.auth.uid;

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // BULK SALES COLLECTION
    // ============================================
    match /bulk_sales/{saleId} {
      // Organisateurs : Lecture de leurs propres ventes en bloc
      allow read: if isAuthenticated() &&
                    resource.data.organizer_id == request.auth.uid;

      // Admin : Accès total pour gérer les stocks en bloc
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // AGENT ACCESS CODES COLLECTION (EPscan)
    // ============================================
    match /agent_access_codes/{codeId} {
      // Lecture pour tous les authentifiés
      allow read: if isAuthenticated();

      // Admin Finance : Accès total
      allow write: if isAdminFinance();
    }

    // ============================================
    // AGENT SCANS COLLECTION (EPscan)
    // ============================================
    match /agent_scans/{scanId} {
      // Lecture pour tous les authentifiés
      allow read: if isAuthenticated();

      // Création par tous les authentifiés (agents qui scannent)
      allow create: if isAuthenticated();

      // Admin Finance : Accès total
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // MARITIME USERS COLLECTION (SAMA Pass)
    // ============================================
    match /maritime_users/{userId} {
      // Admin Finance et utilisateurs authentifiés : Lecture
      allow read: if isAuthenticated();

      // Admin Finance : Création, modification et suppression
      allow write: if isAdminFinance();
    }

    // ============================================
    // MARITIME SUBSCRIPTIONS COLLECTION (SAMA Pass)
    // ============================================
    match /maritime_subscriptions/{subId} {
      // Lecture pour tous les authentifiés
      allow read: if isAuthenticated();

      // Création publique (achat SAMA Pass)
      allow create: if true;

      // Admin Finance : Accès total
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // MARITIME BOOKINGS COLLECTION (SAMA Pass - Réservations)
    // ============================================
    match /maritime_bookings/{bookingId} {
      // Lecture publique pour affichage disponibilités
      allow read: if true;

      // Création publique (réservation SAMA Pass)
      allow create: if true;

      // Modification et suppression admin uniquement
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // SAMA_PASS COLLECTION (QR Codes & Abonnements)
    // ============================================
    match /sama_pass/{passId} {
      // Lecture publique pour scanner
      allow read: if true;

      // Création publique (génération QR)
      allow create: if true;

      // Modification publique (scan, recharge)
      allow update: if true;

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // SAMA_PASS_SCANS COLLECTION (Historique scans)
    // ============================================
    match /sama_pass_scans/{scanId} {
      // Lecture pour authentifiés
      allow read: if isAuthenticated();

      // Création publique (enregistrement scan)
      allow create: if true;

      // Admin : Accès total
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // TRIPS COLLECTION (DemDem Transport)
    // ============================================
    match /trips/{tripId} {
      // Lecture publique des trajets disponibles
      allow read: if true;

      // Création par chauffeurs authentifiés
      allow create: if isAuthenticated() &&
                      request.resource.data.driverId == request.auth.uid;

      // Chauffeur : Modification de ses propres trajets
      allow update: if isAuthenticated() && resource.data.driverId == request.auth.uid;

      // Suppression par chauffeur propriétaire ou admin
      allow delete: if (isAuthenticated() && resource.data.driverId == request.auth.uid) || isAdminFinance();

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // TRANSPORT_VEHICLES COLLECTION (Véhicules)
    // ============================================
    match /transport_vehicles/{vehicleId} {
      // Lecture publique pour affichage
      allow read: if true;

      // Création par OPS Transport et Admin
      allow create: if isOpsManagerTransport() || isAdminFinance();

      // Modification par OPS Transport et Admin
      allow update: if isOpsManagerTransport() || isAdminFinance();

      // Suppression par admin uniquement
      allow delete: if isAdminFinance();
    }

    // ============================================
    // TRANSPORT_LINES COLLECTION (Lignes de transport)
    // ============================================
    match /transport_lines/{lineId} {
      // Lecture publique pour affichage routes
      allow read: if true;

      // Création par OPS Transport et Admin
      allow create: if isOpsManagerTransport() || isAdminFinance();

      // Modification par OPS Transport et Admin
      allow update: if isOpsManagerTransport() || isAdminFinance();

      // Suppression par admin uniquement
      allow delete: if isAdminFinance();
    }

    // ============================================
    // TRANSPORT_SCANS COLLECTION (Scans EPscanT)
    // ============================================
    match /transport_scans/{scanId} {
      // Lecture pour OPS Transport et Admin
      allow read: if isOpsManagerTransport() || isAdminFinance();

      // Création publique (véhicule scanne)
      allow create: if true;

      // Admin : Accès total
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // ACCESS CODES COLLECTION (Vehicle & Staff Access Codes)
    // ============================================
    match /access_codes/{codeId} {
      // Lecture publique pour permettre l'authentification par code
      // Sécurité: Les codes sont pré-générés et limités
      allow read: if true;

      // Création par utilisateurs authentifiés (ops_transport, admin)
      allow create: if isOpsManagerTransport() || isAdminFinance();

      // Modification uniquement par admin
      allow update: if isAdminFinance();

      // Suppression uniquement par admin
      allow delete: if isAdminFinance();
    }

    // ============================================
    // DEMDEM_EXPRESS_SUBSCRIPTIONS COLLECTION (Abonnements chauffeurs)
    // ============================================
    match /demdem_express_subscriptions/{subId} {
      // Lecture publique pour affichage
      allow read: if true;

      // Création publique (achat abonnement)
      allow create: if true;

      // Modification et suppression admin uniquement
      allow update, delete: if isAdminFinance();
    }

    // ============================================
    // TICKETS COLLECTION (Root level - for test tickets)
    // ============================================
    match /tickets/{ticketId} {
      // Lecture publique pour scanner EPscanV
      allow read: if true;

      // Création pour générateur de billets test
      allow create: if true;

      // Modification pour marquer comme scanné
      allow update: if true;

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // TEST CONNECTION COLLECTION
    // ============================================
    match /_connection_test/{testId} {
      // Lecture pour test de connexion
      allow read: if true;
    }

    // ============================================
    // COMMISSIONS COLLECTION (Tracking commissions)
    // ============================================
    match /commissions/{commissionId} {
      // Lecture pour admin uniquement
      allow read: if isAdminFinance();

      // Création et modification par admin uniquement
      allow write: if isAdminFinance();
    }

    // ============================================
    // WALLET TRANSACTIONS COLLECTION (Historique portefeuille chauffeur)
    // ============================================
    match /wallet_transactions/{transactionId} {
      // Lecture pour utilisateur concerné
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Création lors d'une transaction
      allow create: if isAuthenticated();

      // Admin : Accès total
      allow read, write: if isAdminFinance();
    }

    // ============================================
    // BLOCAGE PAR DÉFAUT
    // ============================================
    // Toute autre collection est bloquée par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
